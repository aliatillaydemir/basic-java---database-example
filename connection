package datab;

import java.sql.Connection;
import java.sql.DriverManager;
import java.sql.ResultSet;
import java.sql.SQLException;
import java.sql.Statement;


public class Datab {

    
    public static void main(String[] args) {
       
        Connection con;
        Statement st;
        ResultSet rs;
        
        try
        {
           //DriverManager.getConnection("jdbc:msyql://localhost:3306/yemek","root","parola");
            con = DriverManager.getConnection("jdbc:mysql://localhost/yemek?useUnicode=true&useLegacyDatetimeCode=false&serverTimezone=Turkey","root","parola"); //?useUnicode=true&useLegacyDatetimeCode=false&serverTimezone=Turkey we use this part of code because of turkish character is not support.
             
            st = con.createStatement();
            rs=st.executeQuery("select * from yemek.yenen");
        
            while(rs.next())
            {
                System.out.println("isim: "+rs.getString(1));
                System.out.println("tat: "+rs.getString(2));
                System.out.println("overall: "+rs.getInt(3));
                System.out.println("\n");
            }
            
        }
        catch(SQLException e)
        {
            System.out.println("Error: "+e.getMessage());
        }
        
        
    }
    
}
